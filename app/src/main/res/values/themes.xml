<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema Base do App - Fundo idêntico à Splash para transição invisível -->
    <style name="Theme.DotConnect" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#060D26</item>
        <item name="android:statusBarColor">#060D26</item>
        <item name="android:navigationBarColor">#060D26</item>
    </style>

    <!-- Tema da Splash Screen Nativa -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#060D26</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_native</item>
        <!-- O segredo: o Android já prepara o tema real enquanto a splash nativa está na tela -->
        <item name="postSplashScreenTheme">@style/Theme.DotConnect</item>
    </style>
</resources>